# ============================================================
# Yuno Agent Platform — Environment Configuration
# Copy this file to .env and fill in values
# ============================================================

# ---- Application ----
APP_NAME="Yuno Agent Platform"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://yuno:yuno_password@localhost:5432/yuno_agents
DATABASE_URL_SYNC=postgresql://yuno:yuno_password@localhost:5432/yuno_agents

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=agent_jobs

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-min-32-chars
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
# For local dev, use ngrok: https://abc123.ngrok.io/api/telegram/webhook

# ---- LangGraph ----
LANGGRAPH_CHECKPOINT_TABLE=langgraph_checkpoints
LANGGRAPH_MAX_ITERATIONS=10
LANGGRAPH_TIMEOUT_SECONDS=120

# ---- Cost Controls ----
MAX_COST_PER_EXECUTION=0.50
MAX_TOKENS_PER_EXECUTION=50000

# ---- CORS ----
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ---- Observability ----
ENABLE_METRICS=true
LOG_SQL_QUERIES=false

# ---- Demo Mode ----
# Set to true to use mock LLM, in-memory DB, skip Telegram
DEMO_MODE=false
